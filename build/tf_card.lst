 242:tf_card.c     **** 		if ((resp & 0x1F) != 0x05) return 0;	/* Function fails if the data packet was not accepted */
 243:tf_card.c     **** 	}
 244:tf_card.c     **** 	return 1;
 245:tf_card.c     **** }
