 203:tf_card.c     **** 
 204:tf_card.c     **** static
 205:tf_card.c     **** int rcvr_datablock (	/* 1:OK, 0:Error */
 206:tf_card.c     **** 	BYTE *buff,			/* Data buffer */
 207:tf_card.c     **** 	UINT btr			/* Data block length (byte) */
 208:tf_card.c     **** )
 209:tf_card.c     **** {
 210:tf_card.c     **** 	BYTE token;
 211:tf_card.c     **** 
 212:tf_card.c     **** 	tf_start_timer(200);
 213:tf_card.c     **** 	do {							/* Wait for DataStart token in timeout of 200ms */
 214:tf_card.c     **** 		token = xchg_spi(0xFF);
 215:tf_card.c     **** 		/* This loop will take a time. Insert rot_rdq() here for multitask envilonment. */
 216:tf_card.c     **** 	} while ((token == 0xFF) && tf_timer_done());
GAS LISTING C:\Users\Uzair\AppData\Local\Temp\cc0eZgbn.s 			page 12


 217:tf_card.c     **** 	if(token != 0xFE) return 0;		/* Function fails if invalid DataStart token or timeout */
 218:tf_card.c     **** 
 219:tf_card.c     **** 	rcvr_spi_multi(buff, btr);		/* Store trailing data to the buffer */
 220:tf_card.c     **** 	xchg_spi(0xFF); xchg_spi(0xFF);			/* Discard CRC */
 221:tf_card.c     **** 
 222:tf_card.c     **** 	return 1;						/* Function succeeded */
 223:tf_card.c     **** }
 224:tf_card.c     **** 
 225:tf_card.c     **** static
 226:tf_card.c     **** int xmit_datablock (	/* 1:OK, 0:Failed */
 227:tf_card.c     **** 	const BYTE *buff,	/* Ponter to 512 byte data to be sent */
 228:tf_card.c     **** 	BYTE token			/* Token */
 229:tf_card.c     **** )
 230:tf_card.c     **** {
 231:tf_card.c     **** 	BYTE resp;
 232:tf_card.c     **** 
 233:tf_card.c     **** 
 234:tf_card.c     **** 	if (!wait_ready(500)) return 0;		/* Wait for card ready */
 235:tf_card.c     **** 
 236:tf_card.c     **** 	xchg_spi(token);					/* Send token */
 237:tf_card.c     **** 	if (token != 0xFD) {				/* Send data if token is other than StopTran */
